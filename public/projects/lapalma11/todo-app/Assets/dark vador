//////////////////////// DOM Elements////////////////////////////////////////
const startScreen = document.getElementById("start-screen");
const gameScreen = document.getElementById("game-screen");
const gameoverScreen = document.getElementById("gameover-screen");
const playerHPBar = document.getElementById("player-hp-bar");
const playerHPText = document.getElementById("player-hp-text");
const enemyHPBar = document.getElementById("enemy-hp-bar");
const enemyHPText = document.getElementById("enemy-hp-text");
const enemyMaxHPText = document.getElementById("enemy-max-hp");
const enemyName = document.getElementById("enemy-name");
const enemySprite = document.getElementById("enemy-sprite");
const playerSprite = document.getElementById("player-sprite");
const questionText = document.getElementById("question-text");
const codeBlock = document.getElementById("code-block");
const topicBadge = document.getElementById("topic-badge");
const movesGrid = document.getElementById("moves-grid");
const resultMessage = document.getElementById("result-message");
const nextBtn = document.getElementById("next-btn");
const scoreDisplay = document.getElementById("score");
const streakDisplay = document.getElementById("streak");
const battleArena = document.getElementById("battle-arena");

function startGame() {
  startScreen.classList.add("hidden");
  gameScreen.classList.remove("hidden");
  gameoverScreen.classList.add("hidden");

  playerHP = 100;
  currentEnemy = 0;
  score = 0;
  streak = 0;
  bestStreak = 0;
  enemiesDefeated = 0;

  loadEnemy();
  loadQuestion();
  updateUI();
}

function loadEnemy() {
  const enemy = enemies[currentEnemy];
  enemyMaxHP = enemy.hp;
  enemyHP = enemy.hp;
  enemyName.textContent = enemy.name;
  enemySprite.textContent = enemy.sprite;
  enemyMaxHPText.textContent = enemy.hp;
  updateUI();
}

function getQuestionForEnemy() {
  const enemy = enemies[currentEnemy];
  let pool;

  if (enemy.topic === "mixed") {
    // Final boss - mix of all topics
    const allTopics = [
      "basics",
      "structure",
      "attributes",
      "semantic",
      "mixed",
    ];
    const randomTopic = allTopics[Math.floor(Math.random() * allTopics.length)];
    pool = questions[randomTopic];
  } else {
    pool = questions[enemy.topic];
  }

  return pool[Math.floor(Math.random() * pool.length)];
}

function loadQuestion() {
  currentMove = getQuestionForEnemy();
  const enemy = enemies[currentEnemy];

  // Set topic badge
  const topicNames = {
    basics: "Level 1",
    structure: "Level 2",
    attributes: "Links, Images & Attributes",
    semantic: "Semantic HTML & Lists",
    mixed: "Final Boss",
  };
  topicBadge.textContent =
    enemy.topic === "mixed" ? "Final Boss - Mixed" : topicNames[enemy.topic];

  questionText.textContent = currentMove.question;

  // Handle code block
  if (currentMove.code) {
    codeBlock.textContent = currentMove.code;
    codeBlock.classList.remove("hidden");
  } else {
    codeBlock.classList.add("hidden");
  }

  // Clear and populate answers
  movesGrid.innerHTML = "";
  currentMove.answers.forEach((answer, index) => {
    const btn = document.createElement("button");
    btn.className = "answer-btn";
    btn.textContent = answer;
    btn.onclick = () => selectAnswer(index);
    movesGrid.appendChild(btn);
  });

  resultMessage.classList.add("hidden");
  nextBtn.classList.add("hidden");
}

function selectAnswer(index) {
  const buttons = movesGrid.querySelectorAll(".answer-btn");
  buttons.forEach((btn) => (btn.disabled = true));

  const isCorrect = index === currentMove.correct;

  buttons[index].classList.add(isCorrect ? "correct" : "incorrect");
  if (!isCorrect) {
    buttons[currentMove.correct].classList.add("correct");
  }

  if (isCorrect) {
    handleCorrectAnswer();
  } else {
    handleWrongAnswer();
  }

  moveSelected++;
  updateUI();

  // Check for game over or enemy defeated
  setTimeout(() => {
    if (playerHP <= 0) {
      showGameOver(false);
    } else if (enemyHP <= 0) {
      enemiesDefeated++;
      if (currentEnemy >= enemies.length - 1) {
        showGameOver(true);
      } else {
        showEnemyDefeated();
      }
    } else {
      nextBtn.classList.remove("hidden");
    }
  }, 800);
}

function handleCorrectAnswer() {
  streak++;
  if (streak > bestStreak) bestStreak = streak;

  // Calculate damage (base 20 + streak bonus)
  let damage = 20 + streak * 3;
  let isCritical = false;

  // Critical hit chance at high streaks
  if (streak >= 3 && Math.random() < 0.3) {
    damage = Math.floor(damage * 1.5);
    isCritical = true;
  }

  enemyHP = Math.max(0, enemyHP - damage);
  score += 100 + streak * 25;

  // Animations
  playerSprite.style.animation = "attack-right 0.3s";
  setTimeout(() => {
    enemySprite.style.animation = "damage-shake 0.3s";
    showDamageNumber(damage, "dealt", isCritical);
  }, 150);

  setTimeout(() => {
    playerSprite.style.animation = "";
    enemySprite.style.animation = "";
  }, 500);

  // Streak bonus notification
  if (streak >= 3) {
    showStreakBonus(streak);
  }

  resultMessage.className = "result-message victory";
  resultMessage.innerHTML = isCritical
    ? "<strong>&#9889; CRITICAL HIT!</strong> You dealt " +
      damage +
      " damage!<br><em>" +
      currentMove.explanation +
      "</em>"
    : "<strong>&#10003; Correct!</strong> You dealt " +
      damage +
      " damage!<br><em>" +
      currentMove.explanation +
      "</em>";
  resultMessage.classList.remove("hidden");
}

function handleWrongAnswer() {
  streak = 0;
  const enemy = enemies[currentEnemy];
  const damage = enemy.damage;

  playerHP = Math.max(0, playerHP - damage);

  // Animations
  enemySprite.style.animation = "attack-left 0.3s";
  setTimeout(() => {
    playerSprite.style.animation = "damage-shake 0.3s";
    showDamageNumber(damage, "taken", false);
  }, 150);

  setTimeout(() => {
    playerSprite.style.animation = "";
    enemySprite.style.animation = "";
  }, 500);

  resultMessage.className = "result-message defeat";
  resultMessage.innerHTML =
    "<strong>&#10007; Wrong!</strong> " +
    enemy.name +
    " dealt " +
    damage +
    " damage to you!<br><em>" +
    currentMove.explanation +
    "</em>";
  resultMessage.classList.remove("hidden");
}

function showDamageNumber(amount, type, isCritical) {
  const dmgEl = document.createElement("div");
  dmgEl.className = `damage-number damage-${type}${
    isCritical ? " critical-hit" : ""
  }`;
  dmgEl.textContent = `-${amount}`;
  battleArena.appendChild(dmgEl);

  setTimeout(() => dmgEl.remove(), 1000);
}

function showStreakBonus(streakCount) {
  const bonusEl = document.createElement("div");
  bonusEl.className = "streak-bonus";
  bonusEl.textContent = "\u{1F525} " + streakCount + "x Streak Bonus!";
  battleArena.appendChild(bonusEl);

  setTimeout(() => bonusEl.remove(), 1500);
}

function showEnemyDefeated() {
  resultMessage.className = "result-message victory";
  resultMessage.innerHTML =
    "<strong>&#127881; Enemy Defeated!</strong> " +
    enemies[currentEnemy].name +
    " has been vanquished!";
  resultMessage.classList.remove("hidden");

  nextBtn.textContent = "Next Enemy →";
  nextBtn.classList.remove("hidden");
  nextBtn.onclick = () => {
    currentEnemy++;
    loadEnemy();
    loadQuestion();
    nextBtn.textContent = "Continue";
    nextBtn.onclick = nextQuestion;
  };
}

function nextQuestion() {
  loadQuestion();
}

function updateUI() {
  playerHPBar.style.width = `${(playerHP / playerMaxHP) * 100}%`;
  playerHPText.textContent = playerHP;

  enemyHPBar.style.width = `${(enemyHP / enemyMaxHP) * 100}%`;
  enemyHPText.textContent = enemyHP;

  scoreDisplay.textContent = score;
  streakDisplay.textContent = streak;
}

function showGameOver(victory) {
  gameScreen.classList.add("hidden");
  gameoverScreen.classList.remove("hidden");

  const title = document.getElementById("gameover-title");
  const stats = document.getElementById("final-stats");

  if (victory) {
    title.textContent = "\u{1F3C6} Victory!";
    title.className = "game-over-title victory";
  } else {
    title.textContent = "\u{1F480} Defeated";
    title.className = "game-over-title defeat";
  }

  stats.innerHTML = `
                Enemies Defeated: <span>${enemiesDefeated}</span><br>
                Final Score: <span>${score}</span><br>
                Best Streak: <span>${bestStreak}</span><br>
                Moves Made: <span>${moveSelected}</span>
            `;
}
